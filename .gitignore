#     https://www.atlassian.com/git/tutorials/saving-changes/gitignore

#Application Secrets Files
*.pub
*private_key

#Application Files 
*.json
*.txt
docker_build.sh
README.md
.images/

# Python Virtual Environment
.venv/
venv/
env/
.env/
pyvenv.cfg
__pycache__/
.pytest_cache

#Python compiled files
*.pyc
*.pyo
*.pyd
*.py[cod]

# Log/Temp Files
*.log
*.temp
temp/
temp*
*temp

# Node artifact files
node_modules/
dist/

# gcloud Files
.gcloudignore

# Terraform Files
.terraform/
.terraform*

# Package and Build files
target/
dist/

# Java Files
*.jar
*.class

#IDE Files
.vscode
*.ndb
.idea

# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

